# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here

# Database (SQLite for local dev, change for production)
DATABASE_URL="file:./dev.db"

# ── Optional ──────────────────────────────────────────────────────────────────
# CORS origin (defaults to * if not set)
CORS_ORIGIN=*

# App branding (shown on login page and sidebar)
NEXT_PUBLIC_APP_NAME=WholesaleOS
NEXT_PUBLIC_APP_TAGLINE=Enterprise Wholesale Management

# Node environment
NODE_ENV=production
